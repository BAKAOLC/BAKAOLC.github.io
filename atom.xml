    <content type="html"><![CDATA[<h1><span id="github&#x7B80;&#x6613;&#x4F7F;&#x7528;&#x6559;&#x7A0B;">Github&#x7B80;&#x6613;&#x4F7F;&#x7528;&#x6559;&#x7A0B;</span><a href="#github&#x7B80;&#x6613;&#x4F7F;&#x7528;&#x6559;&#x7A0B;" class="header-anchor"></a></h1><blockquote><p>&#x672C;&#x7BC7;&#x6587;&#x7AE0;&#x5185;&#x63D0;&#x5230;&#x7684;&#x8F6F;&#x4EF6;&#x5747;&#x53EF;&#x5728;&#x8BE5;&#x767E;&#x5EA6;&#x7F51;&#x76D8;&#x4E2D;&#x4E0B;&#x8F7D;&#xFF1A;<a href="&#x94FE;&#x63A5;&#xFF1A;https://pan.baidu.com/s/1gv_5Ik6DQbbJ0GiEvaSrqg">r56w</a>  </p></blockquote><p>&#x672C;&#x7BC7;&#x6587;&#x7AE0;&#x9762;&#x5411;&#x96F6;&#x57FA;&#x7840;&#x7684;&#x7528;&#x6237;&#x7F16;&#x5199;&#xFF0C;&#x56E0;&#x6B64;&#x4E0D;&#x4F1A;&#x8FDB;&#x884C;&#x8FC7;&#x4E8E;&#x5168;&#x9762;&#x7684;&#x8BB2;&#x89E3;&#xFF0C;&#x4EC5;&#x63D0;&#x4F9B;&#x57FA;&#x7840;&#x7684;&#x64CD;&#x4F5C;&#xFF0C;&#x4EE5;&#x4FBF;&#x5FEB;&#x901F;&#x7684;&#x4E0A;&#x624B;&#x3002;  </p><hr><h2><span id="&#x51C6;&#x5907;&#x5DE5;&#x4F5C;">&#x51C6;&#x5907;&#x5DE5;&#x4F5C;</span><a href="#&#x51C6;&#x5907;&#x5DE5;&#x4F5C;" class="header-anchor"></a></h2><p>&#x5728;&#x4F7F;&#x7528; <a href="https://github.com" target="_blank" rel="noopener">Github</a> &#x524D;&#xFF0C;&#x6211;&#x4EEC;&#x9996;&#x5148;&#x9700;&#x8981;&#x6CE8;&#x518C;&#x4E00;&#x4E2A;&#x8D26;&#x6237;<br>&#x5177;&#x4F53;&#x600E;&#x4E48;&#x6CE8;&#x518C;&#x5728;&#x8FD9;&#x6211;&#x5C31;&#x4E0D;&#x8FDB;&#x884C;&#x8FC7;&#x591A;&#x8BF4;&#x660E;&#x4E86;&#xFF0C;&#x524D;&#x5F80;&#x5B98;&#x7F51;&#x81EA;&#x5DF1;&#x6CE8;&#x518C;&#x4E00;&#x4E2A;&#x5C31;&#x884C;  </p><p>&#x5BF9;&#x4E8E;&#x9700;&#x8981;&#x8FDB;&#x884C;&#x6587;&#x672C;&#x7F16;&#x8F91;&#x7684;&#xFF0C;&#x6211;&#x5728;&#x8FD9;&#x63A8;&#x8350;&#x5B89;&#x88C5; <a href="https://notepad-plus-plus.org/downloads/" target="_blank" rel="noopener">Notepad++</a>  </p><p>&#x5728;&#x4E4B;&#x540E;&#xFF0C;&#x6211;&#x4EEC;&#x9700;&#x8981;&#x5B89;&#x88C5;&#x4E00;&#x4E2A; Git &#x7528;&#x4E8E;&#x65B9;&#x4FBF;&#x5FEB;&#x6377;&#x7684;&#x8FDB;&#x884C;&#x5404;&#x79CD;&#x64CD;&#x4F5C;&#xFF1A;<a href="https://git-scm.com/downloads" target="_blank" rel="noopener">&#x4E0B;&#x8F7D;&#x5730;&#x5740;</a>  </p><img src="/posts/218e/Git1.png" class>  <img src="/posts/218e/Git2.png" class>  <blockquote><p>&#x5B89;&#x88C5;&#x65F6;&#xFF0C;&#x5728; <strong>Select Components</strong> &#x6B65;&#x9AA4;&#x8BF7;&#x53D6;&#x6D88;&#x6389; <strong>Git GUI Here</strong> &#x7684;&#x590D;&#x9009;&#x6846;&#xFF0C;&#x56E0;&#x4E3A;Git&#x63D0;&#x4F9B;&#x7684;&#x8FD9;&#x4E2A;&#x7A97;&#x53E3;&#x754C;&#x9762;&#x5E76;&#x4E0D;&#x597D;&#x7528;&#xFF0C;&#x5728;&#x4E0B;&#x9762;&#x4F1A;&#x63D0;&#x4F9B;&#x66F4;&#x597D;&#x7684;&#x9009;&#x62E9;&#x3002;<br>&#x800C;&#x5728; <strong>Choosing the default editor used by Git</strong> &#x6B65;&#x9AA4;&#xFF0C;&#x5982;&#x679C;&#x5B89;&#x88C5;&#x4E86;Notepad++&#xFF0C;&#x53EF;&#x4EE5;&#x5C06;&#x6B64;&#x9879;&#x4FEE;&#x6539;&#x4E3A; <strong>Use Notepad++ as Git&#x2019;s default editor</strong><br>&#x9664;&#x6B64;&#x4E4B;&#x5916;&#x4E00;&#x8DEF;Next&#x5B89;&#x88C5;&#x5373;&#x53EF;  </p></blockquote><p>&#x7531;&#x4E8E; Git &#x662F;&#x4F7F;&#x7528;&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x64CD;&#x4F5C;&#x7684;&#xFF0C;&#x5BF9;&#x4E8E;&#x5927;&#x90E8;&#x5206;&#x57FA;&#x7840;&#x7528;&#x6237;&#x6765;&#x8BF4;&#xFF0C;&#x8FD9;&#x662F;&#x5341;&#x5206;&#x56F0;&#x96BE;&#x7684;&#x64CD;&#x4F5C;&#x3002;&#x56E0;&#x6B64;&#xFF0C;&#x6211;&#x4EEC;&#x53EF;&#x4EE5;&#x5B89;&#x88C5; TortoiseGit &#x6765;&#x8F85;&#x52A9;&#x64CD;&#x4F5C;&#xFF0C;&#x5B89;&#x88C5;&#x4E86;&#x8FD9;&#x4E2A;&#x5DE5;&#x5177;&#x540E;&#xFF0C;&#x6211;&#x4EEC;&#x4FBF;&#x53EF;&#x4EE5;&#x901A;&#x8FC7;&#x53F3;&#x952E;&#x83DC;&#x5355;&#x5B8C;&#x6210; Git &#x7684;&#x5404;&#x9879;&#x64CD;&#x4F5C;&#xFF0C;&#x5341;&#x5206;&#x65B9;&#x4FBF;&#xFF1A;<a href="https://tortoisegit.org/download/" target="_blank" rel="noopener">&#x4E0B;&#x8F7D;&#x5730;&#x5740;</a>  </p><blockquote><p>&#x5B83;&#x8FD8;&#x63D0;&#x4F9B;&#x4E86;&#x4E2D;&#x6587;&#x8BED;&#x8A00;&#x5305;&#xFF0C;&#x5BF9;&#x4E8E;&#x82F1;&#x6587;&#x6BD4;&#x8F83;&#x5DEE;&#x7684;&#x7528;&#x6237;&#x6765;&#x8BF4;&#xFF0C;&#x8FD9;&#x4E2A;&#x5B9E;&#x5728;&#x662F;&#x592A;&#x65B9;&#x4FBF;&#x4E86;  </p></blockquote><p>&#x5B89;&#x88C5;&#x5B8C; TortoiseGit &#x4E4B;&#x540E;&#xFF0C;&#x5728;&#x684C;&#x9762;&#x6216;&#x4EFB;&#x610F;&#x6587;&#x4EF6;&#x5939; <strong>&#x53F3;&#x952E; -&gt; TortoiseGit -&gt; &#x8BBE;&#x7F6E;</strong> &#x8FDB;&#x5165;&#x8BBE;&#x7F6E;&#x754C;&#x9762;<br>&#x4E4B;&#x540E;&#x70B9;&#x51FB;&#x8FDB;&#x5165; <strong>Git</strong> &#x8BBE;&#x7F6E;&#x754C;&#x9762;&#xFF0C;&#x9009;&#x62E9; <strong>&#x5168;&#x5C40;</strong>&#xFF0C;&#x53D6;&#x6D88;&#x6389; <strong>&#x7528;&#x6237;&#x4FE1;&#x606F;</strong> &#x7684; <strong>&#x540D;&#x79F0;</strong> &#x4E0E; <strong>Email</strong> &#x7684;&#x7EE7;&#x627F;&#x590D;&#x9009;&#x6846;&#xFF0C;&#x5E76;&#x586B;&#x5199;&#x4F60;&#x6CE8;&#x518C;&#x7684; Github &#x8D26;&#x6237;&#x4FE1;&#x606F;&#xFF0C;&#x4E4B;&#x540E;&#x70B9;&#x51FB; <strong>&#x786E;&#x5B9A;</strong> &#x4FDD;&#x5B58;&#x914D;&#x7F6E;  </p><img src="/posts/218e/TortoiseGit1.png" class>  <img src="/posts/218e/TortoiseGit2.png" class>  <p>&#x5B8C;&#x6210;&#x4EE5;&#x4E0A;&#x64CD;&#x4F5C;&#x540E;&#xFF0C;&#x57FA;&#x7840;&#x7684;&#x51C6;&#x5907;&#x5DE5;&#x4F5C;&#x5C31;&#x90FD;&#x5B8C;&#x6210;&#x4E86;&#x3002;</p><hr><h2><span id="&#x5C06;-github-&#x4ED3;&#x5E93;&#x514B;&#x9686;&#x81F3;&#x672C;&#x5730;">&#x5C06; Github &#x4ED3;&#x5E93;&#x514B;&#x9686;&#x81F3;&#x672C;&#x5730;</span><a href="#&#x5C06;-github-&#x4ED3;&#x5E93;&#x514B;&#x9686;&#x81F3;&#x672C;&#x5730;" class="header-anchor"></a></h2><blockquote><p>&#x8BE5;&#x90E8;&#x5206;&#x5185;&#x5BB9;&#x9ED8;&#x8BA4;&#x7528;&#x6237;&#x5DF2;&#x5B8C;&#x6210;&#x51C6;&#x5907;&#x5DE5;&#x4F5C;&#x4E2D;&#x7684;&#x914D;&#x7F6E;&#x64CD;&#x4F5C;</p></blockquote><h3><span id="&#x901A;&#x8FC7;&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;">&#x901A;&#x8FC7;&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;</span><a href="#&#x901A;&#x8FC7;&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;" class="header-anchor"></a></h3><p>&#x51C6;&#x5907;&#x5DE5;&#x4F5C;&#x5B8C;&#x6210;&#x540E;&#xFF0C;&#x6211;&#x4EEC;&#x8981;&#x5BF9; Github &#x4E0A;&#x7684;&#x4ED3;&#x5E93;&#x8FDB;&#x884C;&#x64CD;&#x4F5C;&#xFF0C;&#x6211;&#x4EEC;&#x9996;&#x5148;&#x9700;&#x8981;&#x5BF9;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x6267;&#x884C; <strong>Fork</strong> &#x64CD;&#x4F5C;&#xFF08;&#x8FDB;&#x5165;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x5730;&#x5740;&#xFF0C;&#x70B9;&#x51FB;&#x53F3;&#x4E0A;&#x89D2;&#x7684; <strong>Fork</strong> &#x6309;&#x94AE;&#xFF0C;&#x4F1A;&#x81EA;&#x52A8;&#x7EE7;&#x627F;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x5230;&#x81EA;&#x8EAB;&#x8D26;&#x6237;&#x4E2D;&#x521B;&#x5EFA;&#x4E00;&#x4E2A;&#x5BF9;&#x5E94;&#x7684;&#x4ED3;&#x5E93;&#xFF09;<br>&#x4E4B;&#x540E;&#xFF0C;&#x5728;&#x81EA;&#x8EAB;&#x8D26;&#x6237;Fork&#x51FA;&#x7684;&#x4ED3;&#x5E93;&#x4E2D;&#xFF0C;&#x70B9;&#x51FB; <strong>Clone or Download</strong> &#x6309;&#x94AE;&#xFF0C;&#x5E76;&#x590D;&#x5236;&#x5185;&#x90E8;&#x7684;&#x94FE;&#x63A5;&#xFF0C;&#x4E4B;&#x540E;&#x5373;&#x53EF;&#x5728;&#x672C;&#x5730;&#x8FDB;&#x884C;&#x514B;&#x9686;&#x64CD;&#x4F5C;&#x4E86;  </p><h3><span id="&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;">&#x901A;&#x8FC7; Git &#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;</span><a href="#&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x8FDB;&#x884C;&#x514B;&#x9686;" class="header-anchor"></a></h3><p>&#x8C03;&#x7528; CMD &#x4F7F;&#x7528; cd &#x547D;&#x4EE4;&#x81F3;&#x60F3;&#x8981;&#x4FDD;&#x5B58;&#x7684;&#x4F4D;&#x7F6E;&#x6216;&#x5728;&#x76EE;&#x6807;&#x4F4D;&#x7F6E;&#x901A;&#x8FC7; <strong>&#x53F3;&#x952E; -&gt; Git Bash Here</strong> &#x5F00;&#x542F; Git &#x7684;&#x547D;&#x4EE4;&#x884C;&#x754C;&#x9762;&#xFF0C;&#x7136;&#x540E;&#x8F93;&#x5165;  </p><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span></pre></td><td class="code"><pre><span class="line">git clone &#x4F60;&#x521A;&#x521A;&#x590D;&#x5236;&#x7684;&#x94FE;&#x63A5;</span></pre></td></tr></table></figure><p>&#x56DE;&#x8F66;&#x5373;&#x53EF;&#x81EA;&#x52A8;&#x5F00;&#x59CB;&#x514B;&#x9686;&#x64CD;&#x4F5C;<br>&#x514B;&#x9686;&#x5B8C;&#x6210;&#x540E;&#xFF0C;&#x901A;&#x8FC7; cd &#x547D;&#x4EE4;&#x8FDB;&#x5165;&#x5230;&#x514B;&#x9686;&#x51FA;&#x7684;&#x672C;&#x5730;&#x4ED3;&#x5E93;&#x6587;&#x4EF6;&#x5939;&#x4E2D;&#xFF0C;&#x6267;&#x884C;  </p><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span></pre></td><td class="code"><pre><span class="line">git remote add upstream &#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x7684;&#x514B;&#x9686;&#x94FE;&#x63A5;</span></pre></td></tr></table></figure><p>&#x6765;&#x521B;&#x5EFA;&#x4E00;&#x4E2A;&#x540D;&#x4E3A; <strong>upstream</strong> &#x7684;&#x8FDC;&#x7AEF;&#x76EE;&#x6807;&#xFF0C;&#x7528;&#x4E8E;&#x5BF9;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x4FDD;&#x6301;&#x66F4;&#x65B0;  </p><h3><span id="&#x901A;&#x8FC7;-tortoisegit-&#x8FDB;&#x884C;&#x514B;&#x9686;">&#x901A;&#x8FC7; TortoiseGit &#x8FDB;&#x884C;&#x514B;&#x9686;</span><a href="#&#x901A;&#x8FC7;-tortoisegit-&#x8FDB;&#x884C;&#x514B;&#x9686;" class="header-anchor"></a></h3><p>&#x5728;&#x672C;&#x5730;&#x7535;&#x8111;&#x4E2D;&#x4F60;&#x60F3;&#x8981;&#x4FDD;&#x5B58;&#x7684;&#x4F4D;&#x7F6E; <strong>&#x53F3;&#x952E; -&gt; Git&#x514B;&#x9686;&#x2026;</strong>&#xFF0C;&#x5728; URL &#x5904;&#x586B;&#x5199;&#x4F60;&#x521A;&#x521A;&#x590D;&#x5236;&#x51FA;&#x7684;&#x94FE;&#x63A5;&#x5730;&#x5740;&#xFF0C;&#x70B9;&#x51FB; <strong>&#x786E;&#x5B9A;</strong> &#x5373;&#x53EF;&#x81EA;&#x52A8;&#x5F00;&#x59CB;&#x514B;&#x9686;&#x6587;&#x4EF6;&#x5230;&#x672C;&#x5730;&#x3002;<br>&#x514B;&#x9686;&#x5B8C;&#x6210;&#x540E;&#xFF0C;&#x8FDB;&#x5165;&#x5230;&#x514B;&#x9686;&#x51FA;&#x7684;&#x672C;&#x5730;&#x4ED3;&#x5E93;&#x6587;&#x4EF6;&#x5939;&#x4E2D; <strong>&#x53F3;&#x952E; -&gt; TortoiseGit -&gt; &#x8BBE;&#x7F6E;</strong> &#x8FDB;&#x5165;&#x8BBE;&#x7F6E;&#x754C;&#x9762;<br>&#x4E4B;&#x540E;&#x70B9;&#x51FB;&#x8FDB;&#x5165; <strong>Git - &#x8FDC;&#x7AEF;</strong> &#x8BBE;&#x7F6E;&#x754C;&#x9762;&#xFF0C;&#x5728; <strong>&#x8FDC;&#x7AEF;</strong> &#x5904;&#x8F93;&#x5165; <strong>upstream</strong> &#x5E76;&#x5728; URL &#x5904;&#x586B;&#x5199;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x7684;&#x514B;&#x9686;&#x94FE;&#x63A5;&#xFF0C;&#x518D;&#x70B9;&#x51FB; <strong>&#x6DFB;&#x52A0;/&#x4FDD;&#x5B58;(A)</strong> &#x6309;&#x94AE;&#x6765;&#x521B;&#x5EFA;&#x8FDC;&#x7AEF;&#x76EE;&#x6807;&#xFF0C;&#x7528;&#x4E8E;&#x5BF9;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x4FDD;&#x6301;&#x66F4;&#x65B0;&#xFF0C;&#x518D;&#x70B9;&#x51FB; <strong>&#x786E;&#x5B9A;</strong> &#x4FDD;&#x5B58;&#x914D;&#x7F6E;  </p><img src="/posts/218e/Clone1.png" class>  <img src="/posts/218e/Clone2.png" class>  <img src="/posts/218e/Clone3.png" class>  <h2><span id="&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3;-fork-&#x4ED3;&#x5E93;">&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3; Fork &#x4ED3;&#x5E93;</span><a href="#&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3;-fork-&#x4ED3;&#x5E93;" class="header-anchor"></a></h2><p>&#x8981;&#x5BF9;&#x4ED3;&#x5E93;&#x6587;&#x4EF6;&#x8FDB;&#x884C;&#x4FEE;&#x6539;&#xFF0C;&#x53EF;&#x4EE5;&#x76F4;&#x63A5;&#x7B80;&#x5355;&#x7684;&#x5BF9;&#x514B;&#x9686;&#x4E0B;&#x6765;&#x7684;&#x672C;&#x5730;&#x4ED3;&#x5E93;&#x8FDB;&#x884C;&#x6587;&#x4EF6;&#x64CD;&#x4F5C;&#x3002;<br>&#x5728;&#x8FD9;&#x4E4B;&#x540E;&#xFF0C;&#x6211;&#x4EEC;&#x9700;&#x8981;&#x8FDB;&#x884C;&#x63D0;&#x4EA4;&#x624D;&#x53EF;&#x5BF9;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x8FDB;&#x884C;&#x4FEE;&#x6539;&#x3002;  </p><h3><span id="&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;">&#x901A;&#x8FC7; Git &#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;</span><a href="#&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;" class="header-anchor"></a></h3><h3><span id="&#x901A;&#x8FC7;-tortoisegit-&#x63D0;&#x4EA4;">&#x901A;&#x8FC7; TortoiseGit &#x63D0;&#x4EA4;</span><a href="#&#x901A;&#x8FC7;-tortoisegit-&#x63D0;&#x4EA4;" class="header-anchor"></a></h3><h2><span id="&#x4ECE;-fork-&#x4ED3;&#x5E93;&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3;&#x539F;&#x76EE;&#x6807;&#x4ED3;&#x5E93;">&#x4ECE; Fork &#x4ED3;&#x5E93;&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3;&#x539F;&#x76EE;&#x6807;&#x4ED3;&#x5E93;</span><a href="#&#x4ECE;-fork-&#x4ED3;&#x5E93;&#x63D0;&#x4EA4;&#x66F4;&#x65B0;&#x81F3;&#x539F;&#x76EE;&#x6807;&#x4ED3;&#x5E93;" class="header-anchor"></a></h2><h3><span id="&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;">&#x901A;&#x8FC7; Git &#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;</span><a href="#&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x63D0;&#x4EA4;" class="header-anchor"></a></h3><h3><span id="&#x901A;&#x8FC7;-tortoisegit-&#x63D0;&#x4EA4;">&#x901A;&#x8FC7; TortoiseGit &#x63D0;&#x4EA4;</span><a href="#&#x901A;&#x8FC7;-tortoisegit-&#x63D0;&#x4EA4;" class="header-anchor"></a></h3><h3><span id="&#x901A;&#x8FC7;-github-&#x7F51;&#x9875;&#x63D0;&#x4EA4;">&#x901A;&#x8FC7; Github &#x7F51;&#x9875;&#x63D0;&#x4EA4;</span><a href="#&#x901A;&#x8FC7;-github-&#x7F51;&#x9875;&#x63D0;&#x4EA4;" class="header-anchor"></a></h3><h2><span id="&#x66F4;&#x65B0;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x5185;&#x5BB9;&#x81F3;-fork-&#x4ED3;&#x5E93;">&#x66F4;&#x65B0;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x5185;&#x5BB9;&#x81F3; Fork &#x4ED3;&#x5E93;</span><a href="#&#x66F4;&#x65B0;&#x76EE;&#x6807;&#x4ED3;&#x5E93;&#x5185;&#x5BB9;&#x81F3;-fork-&#x4ED3;&#x5E93;" class="header-anchor"></a></h2><h3><span id="&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x66F4;&#x65B0;">&#x901A;&#x8FC7; Git &#x547D;&#x4EE4;&#x884C;&#x66F4;&#x65B0;</span><a href="#&#x901A;&#x8FC7;-git-&#x547D;&#x4EE4;&#x884C;&#x66F4;&#x65B0;" class="header-anchor"></a></h3><h3><span id="&#x901A;&#x8FC7;-tortoisegit-&#x66F4;&#x65B0;">&#x901A;&#x8FC7; TortoiseGit &#x66F4;&#x65B0;</span><a href="#&#x901A;&#x8FC7;-tortoisegit-&#x66F4;&#x65B0;" class="header-anchor"></a></h3>]]></content>
    
